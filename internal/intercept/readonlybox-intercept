#!/bin/bash
#
# readonlybox-intercept - Launch commands with LD_PRELOAD interception
#
# Usage:
#   readonlybox-intercept <command> [args...]
#   readonlybox-intercept --shell
#
# This script sets up the LD_PRELOAD environment and launches the command.
# All intercepted commands will be routed through readonlybox.
#

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
INTERCEPT_LIB="${SCRIPT_DIR}/libreadonlybox_intercept.so"
READONLYBOX_BIN="${SCRIPT_DIR}/../../readonlybox"

# Find readonlybox if not in expected location
if [ ! -f "$READONLYBOX_BIN" ]; then
    READONLYBOX_BIN="/usr/local/bin/readonlybox"
fi

if [ ! -f "$READONLYBOX_BIN" ]; then
    READONLYBOX_BIN="/usr/bin/readonlybox"
fi

if [ ! -f "$READONLYBOX_BIN" ]; then
    echo "Error: readonlybox binary not found" >&2
    exit 1
fi

if [ ! -f "$INTERCEPT_LIB" ]; then
    echo "Error: intercept library not found at $INTERCEPT_LIB" >&2
    exit 1
fi

export READONLYBOX_PATH="$READONLYBOX_BIN"
export READONLYBOX_INTERCEPT="$INTERCEPT_LIB"
export LD_PRELOAD="$INTERCEPT_LIB"

# For debugging, uncomment:
# export READONLYBOX_DEBUG=1

if [ $# -eq 0 ]; then
    echo "Usage: $0 <command> [args...]" >&2
    echo "" >&2
    echo "Launch a command with readonlybox interception." >&2
    echo "All known commands will be validated before execution." >&2
    exit 1
fi

exec "$@"
